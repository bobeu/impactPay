# ==========================================
# ImpactPay Environment Configuration Example
# ==========================================
# Copy this file to .env and fill in the values.

# -----------------
# 1. CORE WEB3
# -----------------
# Wallet Connect Project ID (Get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WC_PROJECT_ID="your_project_id_here"
NEXT_PUBLIC_WALLETCONNECT_ID='57c6763cf4e4966b74168daa46a06d2b'
# Celo Network Configuration
CELO_RPC_URL="https://forno.celo.org" # Mainnet: https://forno.celo.org | Sepolia: https://forno.celo-sepolia.celo-testnet.org
IMPACTPAY_CONTRACT_ADDRESS="0x..."

# -----------------
# 2. BACKEND & FULFILLMENT (BITGIFTY)
# -----------------
# API Key for BitGifty (Fulfillment of utility bills)
BITGIFTY_API_KEY="your_bitgifty_key"
BITGIFTY_BASE_URL="https://vbaas.vfdtech.ng" # Production URL

# Shared secret to authorize the fulfillment listener call to /api/fulfill-bill
FULFILL_BILL_SHARED_SECRET="generate_a_secure_random_string"

# Default identifiers for live BitGifty payloads (refer to BitGifty documentation)
BITGIFTY_DIVISION="division_id"
BITGIFTY_PAYMENT_ITEM="item_id"
BITGIFTY_PRODUCT_ID="product_id"
BITGIFTY_BILLER_ID="biller_id"

# -----------------
# 3. VIRTUAL CARDS (CHIMONEY)
# -----------------
# Chimoney API Key (For issuing virtual cards for Developer Subscriptions)
CHIMONEY_API_KEY="your_chimoney_key"
CHIMONEY_BASE_URL="https://api-v2.chimoney.io"
CHIMONEY_WEBHOOK_SECRET="your_webhook_secret"

# AES encryption key (32 bytes / 64 hex chars) to encrypt card details in the store
CARD_ENCRYPTION_KEY="your_64_char_hex_key"

# Default card type (visa/mastercard)
CHIMONEY_CARD_TYPE="visa"

# -----------------
# 4. DATA & IDENTITY
# -----------------
# The Graph Subgraph Endpoint (Used by the frontend and Stats API)
NEXT_PUBLIC_GRAPH_ENDPOINT="https://api.studio.thegraph.com/query/..."

# Issuer DID for Verifiable Credentials (e.g., did:web:impactpay.celo.org)
ISSUER_DID="did:web:impactpay.celo.org"

# -----------------
# 5. RELAYER / SIGNER
# -----------------
# The private key of the account used to verify identities and fulfill bills on-chain
BACKEND_SIGNER_PRIVATE_KEY="0x_your_signer_private_key"

# Base URL of the application (used for listener callbacks)
APP_BASE_URL="http://localhost:3000"
