{
  "name": "smartcontracts",
  "license": "MIT",
  "version": "1.0.0",
  "scripts": {
    "compile": "bunx hardhat compile",
    "test": "bunx hardhat test",
    "contract": "bunx hardhat compile && bunx hardhat test",
    "deploy": "bunx hardhat deploy --network hardhat",
    "deploy:testnet": "hardhat deploy --network testnet --export deployments/contracts.json",
    "deploy:mainnet": "hardhat deploy --network mainnet --export deployments/contracts.json",
    "tsc": "bunx tsc -p . && cp typechain/*.d.ts dist/typechain/",
    "build": "yarn compile && yarn tsc",
    "clean": "hardhat clean"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomiclabs/hardhat-web3": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@thirdweb-dev/contracts": "^3.15.0",
    "dotenv": "^17.2.3",
    "hardhat": "^2.22.17",
    "hardhat-deploy": "^0.12.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.7",
    "@nomicfoundation/hardhat-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-viem": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-viem": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.2.0",
    "@types/chai-as-promised": "^7.1.6",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=18.0.0",
    "chai": "^4.2.0",
    "ethers": "^6.13.7",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.0",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.2",
    "typescript": "~5.0.4",
    "viem": "^2.7.6",
    "web3": "^1.0.0-beta.36"
  },
  "author": "Bobeu"
}