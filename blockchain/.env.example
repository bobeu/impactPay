# HashFlow Protocol — Environment Configuration
# NEVER commit this file. Add to .gitignore.

# ── Wallet / Deployer ─────────────────────────────────────────────────────────
# Address that pays gas and deploys the contracts.
DEPLOYER_ADDRESS=

# Private key of the deployer (used by forge script --private-key).
PRIVATE_KEY=

# Platform owner — receives portion of yield and is Ownable owner of HashFlowEscrow.
PLATFORM_ADDRESS=

# Official USDT (permit2) on HashKey Testnet.
OFFICIAL_USDT_ADDRESS=0x372325443233fEbaC1F6998aC750276468c83CC6

# ── Deployed Contract Addresses (filled after: forge script DeployProduction) ─
# Update these after running the production deployment script and then run:
#   node frontend/sync-artifacts.js
VAULT_ADDRESS=
ESCROW_ADDRESS=
HSP_ADDRESS=
ZK_VERIFIER_ADDR=